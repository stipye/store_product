# Supabase (usado pelas funções em /api)
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=sua-anon-key-aqui

# Chave secreta que o painel /admin e a extensão AfiML devem enviar
# no header "X-API-Secret" para criar, editar ou remover produtos.
API_SECRET=escolha-uma-chave-forte-aqui

# Opcional: use apenas se o frontend precisar apontar para uma API
# hospedada em outro domínio. Deixe vazio para usar o mesmo domínio (/api).
VITE_API_URL=
